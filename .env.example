# Soju Python tooling (CLIs). Copy to `.env` in the repo root or cwd.
# Loaded automatically when the `dev` group is installed (`uv sync` default).
# Shell / Docker exports still win when already set.

# Logging (default: off)
# SOJU_LOG_ENABLED=true
# SOJU_LOG_DESTINATION=file
# SOJU_LOG_DIR=
# SOJU_LOG_LEVEL=DEBUG

# Data and Ollama (optional overrides)
# DATA_DIR=./data
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=gemma4:31b-mlx
# SOJU_LANGUAGE_LEVEL=1A

FROM node:22-alpine AS deps

WORKDIR /app

COPY apps/web/package.json apps/web/package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

FROM deps AS dev

WORKDIR /app
EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]

# Static export (GitHub Pages / offline preview). All PUBLIC_* knobs are build-args.
# Defaults suit a public static host (AI off, browser TTS, site at /).
# Example:
#   docker build -f docker/Dockerfile.web --target build \
#     --build-arg PUBLIC_BASE_PATH=/soju-platform \
#     -t soju-web:static .
# Or: scripts/docker-build-web.sh [extract-dir]
FROM deps AS build

WORKDIR /app

COPY apps/web/ ./
COPY data/ /data/

ARG PUBLIC_BASE_PATH=
ENV PUBLIC_BASE_PATH=$PUBLIC_BASE_PATH

ARG PUBLIC_TTS_ENGINE=browser
ENV PUBLIC_TTS_ENGINE=$PUBLIC_TTS_ENGINE
ARG PUBLIC_TTS_PIPER_BASE_URL=http://localhost:5500
ENV PUBLIC_TTS_PIPER_BASE_URL=$PUBLIC_TTS_PIPER_BASE_URL
ARG PUBLIC_TTS_PIPER_VOICE=ko-KR-SunHiNeural
ENV PUBLIC_TTS_PIPER_VOICE=$PUBLIC_TTS_PIPER_VOICE

ARG PUBLIC_AI_ENABLED=false
ENV PUBLIC_AI_ENABLED=$PUBLIC_AI_ENABLED
ARG PUBLIC_AI_API_MODE=chat-completions
ENV PUBLIC_AI_API_MODE=$PUBLIC_AI_API_MODE
ARG PUBLIC_AI_BASE_URL=http://localhost:11434
ENV PUBLIC_AI_BASE_URL=$PUBLIC_AI_BASE_URL
ARG PUBLIC_AI_MODEL=gemma4:e4b
ENV PUBLIC_AI_MODEL=$PUBLIC_AI_MODEL
ARG PUBLIC_AI_EMBED_MODEL=nomic-embed-text
ENV PUBLIC_AI_EMBED_MODEL=$PUBLIC_AI_EMBED_MODEL
ARG PUBLIC_AI_SYSTEM_PROMPT=
ENV PUBLIC_AI_SYSTEM_PROMPT=$PUBLIC_AI_SYSTEM_PROMPT
ARG PUBLIC_AI_TUTOR_NAME="Hee-jae (희재)"
ENV PUBLIC_AI_TUTOR_NAME=$PUBLIC_AI_TUTOR_NAME

ENV DATA_DIR=/data

RUN npm run build

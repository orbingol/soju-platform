FROM node:22-alpine AS deps

WORKDIR /app

COPY apps/web/package.json apps/web/package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

FROM deps AS dev

WORKDIR /app
EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]

FROM deps AS build

WORKDIR /app

COPY apps/web/ ./
COPY data/ /data/

ENV DATA_DIR=/data
ENV PUBLIC_AI_ENABLED=false
ENV PUBLIC_AI_API_MODE=chat-completions
ENV PUBLIC_BASE_PATH=
ENV PUBLIC_AI_BASE_URL=http://localhost:11434
ENV PUBLIC_AI_MODEL=gemma4:e4b
ENV PUBLIC_AI_SYSTEM_PROMPT=
ENV PUBLIC_AI_TUTOR_NAME="Hee-jae (희재)"

RUN npm run build

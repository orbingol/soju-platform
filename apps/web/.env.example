# Copy to .env for local Vite dev outside Docker (optional — compose sets these in the web service).
PUBLIC_AI_ENABLED=true
PUBLIC_AI_API_MODE=chat-completions
PUBLIC_AI_BASE_URL=http://localhost:11434
PUBLIC_AI_MODEL=gemma4:e4b
PUBLIC_AI_TUTOR_NAME="Hee-jae (희재)"
PUBLIC_AI_CHAT_SUMMARY_TRIGGER=10
PUBLIC_AI_CHAT_KEEP_RECENT=6
PUBLIC_TTS_ENGINE=piper
PUBLIC_TTS_PIPER_BASE_URL=http://localhost:5500
PUBLIC_TTS_PIPER_VOICE=ko-KR-SunHiNeural

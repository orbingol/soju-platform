# Staging drafts (committed staging YAML is tracked after review)
data/staging/**/*.draft.yaml
data/staging/**/*.tmp.yaml

# Local caches (e.g. embedding indexes built by soju embed-index)
data/cache/

# Local import scratch (examples in docs; keep out of git)
/words*.txt
/scratch/**
!/scratch/README.md

# OS junk
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / IDE
*.swp
*~
.idea/
.vs*/
*.sublime-project
*.sublime-workspace
.cursor/plans/

# Local agent notes (template AGENTS.local.md-example is tracked)
AGENTS.local.md

# Local env / secrets
.env
.env.*
!.env.example

# Logs
*.log

# Docker (local overrides only — keep compose + Dockerfile tracked)
docker-compose.override.yml


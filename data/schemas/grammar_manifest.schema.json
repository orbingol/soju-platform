{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soju.local/schemas/grammar_manifest.schema.json",
  "title": "Grammar patterns manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["patterns"],
  "properties": {
    "patterns": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "label", "form", "english", "category"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "form": { "type": "string", "minLength": 1 },
          "english": { "type": "string", "minLength": 1 },
          "category": {
            "type": "string",
            "enum": ["particles", "time_place", "verb_patterns", "question_words", "connectors"]
          },
          "description": { "type": "string", "minLength": 1 }
        }
      },
      "propertyNames": { "pattern": "^[a-z][a-z0-9_]*$" }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soju.local/schemas/topics_topic.schema.json",
  "title": "Topic file with sections",
  "type": "object",
  "additionalProperties": false,
  "required": ["sections"],
  "properties": {
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "$defs": {
    "uuid": { "$ref": "_defs.schema.json#/$defs/uuid" },
    "example": { "$ref": "_defs.schema.json#/$defs/example" },
    "refEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": { "$ref": "#/$defs/uuid" }
      }
    },
    "localEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "local", "hangul", "romanization", "english"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "local": { "const": true },
        "hangul": { "type": "string", "minLength": 1 },
        "romanization": { "type": "string", "minLength": 1 },
        "english": { "type": "string", "minLength": 1 },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" }
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "entries"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "entries": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/refEntry" },
              { "$ref": "#/$defs/localEntry" }
            ]
          }
        }
      }
    }
  }
}

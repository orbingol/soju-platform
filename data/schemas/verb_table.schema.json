{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soju.local/schemas/verb_table.schema.json",
  "title": "Verb table layout",
  "type": "object",
  "additionalProperties": false,
  "required": ["fields", "sections"],
  "properties": {
    "fields": { "$ref": "_defs.schema.json#/$defs/rowFields" },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "$defs": {
    "conjugationColumn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variant", "label", "subtitle"],
      "properties": {
        "variant": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "label": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string", "minLength": 1 },
        "join": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "uniqueItems": true
        },
        "separator": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "variant": { "const": "combined" } }, "required": ["variant"] },
          "then": { "required": ["join"] }
        }
      ]
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "css", "columns"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "css": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/conjugationColumn" }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soju.local/schemas/verbs_construction.schema.json",
  "title": "Verb construction data (placeholder)",
  "type": "object",
  "additionalProperties": false,
  "required": ["construction", "entries"],
  "properties": {
    "construction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "label": { "type": "string", "minLength": 1 },
        "pattern": { "type": "string", "minLength": 1 }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}

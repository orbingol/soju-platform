{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soju.local/schemas/topics_table.schema.json",
  "title": "Default topic table layout",
  "type": "object",
  "additionalProperties": false,
  "required": ["fields"],
  "properties": {
    "fields": { "$ref": "_defs.schema.json#/$defs/rowFields" },
    "examples": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": { "type": "string", "minLength": 1 }
      }
    }
  }
}
